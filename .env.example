# Environment Configuration
# Copy this to .env and fill in your API keys

# LLM Configuration
LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# Optional: Redis for caching
REDIS_URL=redis://localhost:6379

# Server
DEBUG=true
HOST=0.0.0.0
PORT=8000