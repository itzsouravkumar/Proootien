{
  "name": "protein-surface-analyzer-monorepo",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "setup": "npm run setup:python && npm run setup:frontend",
    "setup:venv": "[ -d venv ] || python3 -m venv venv",
    "setup:python": "npm run setup:venv && ./venv/bin/python -m pip install --upgrade pip && ./venv/bin/python -m pip install -r requirements.txt",
    "setup:frontend": "npm --prefix frontend install",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "./venv/bin/python -m uvicorn backend.main:app --port 8000 --reload",
    "dev:frontend": "npm --prefix frontend run dev",
    "train": "./venv/bin/python gnn_training_storyboard.py",
    "train:viz": "./venv/bin/python training_visualization.py",
    "install:all": "npm run setup:frontend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
